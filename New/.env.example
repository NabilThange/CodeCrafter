# ============================================
# Unified Platform — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# ============================================

# ------ Database (PostgreSQL via Supabase) ------
# Connection Pooling URL (for app runtime - use PgBouncer)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct Connection URL (for migrations only)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ------ Application URLs ------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_VANE_URL="http://localhost:3000"
NEXT_PUBLIC_PORTFOLIO_URL="http://localhost:3000/portfolio"
NEXT_PUBLIC_WORLDMONITOR_URL="http://localhost:3000/monitor"

# ------ AI Providers ------

# OpenAI
OPENAI_API_KEY=""

# Anthropic Claude
ANTHROPIC_API_KEY=""

# Google Gemini
GOOGLE_API_KEY=""

# Groq (primary — 14,400 req/day on free tier)
GROQ_API_KEY=""

# OpenRouter (fallback — 50 req/day on free tier)
OPENROUTER_API_KEY=""

# Ollama (self-hosted)
OLLAMA_API_URL=""
OLLAMA_MODEL=""

# ------ Redis Cache (Upstash) ------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ------ Market Data APIs ------

# Finnhub (stock quotes)
FINNHUB_API_KEY=""

# Polygon.io (ETF prices)
POLYGON_API_KEY=""

# Alpha Vantage (fallback ETF prices)
ALPHA_VANTAGE_API_KEY=""

# ------ Economic Data APIs ------

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=""

# U.S. Energy Information Administration
EIA_API_KEY=""

# ------ Aviation & Tracking APIs ------

# AviationStack (live flight data)
AVIATIONSTACK_API=""

# ICAO API (NOTAM airport closures)
ICAO_API_KEY=""

# Wingbits (aircraft enrichment)
WINGBITS_API_KEY=""

# AISStream (vessel tracking)
AISSTREAM_API_KEY=""

# OpenSky Network (aircraft data)
OPENSKY_CLIENT_ID=""
OPENSKY_CLIENT_SECRET=""

# ------ Conflict & Intelligence APIs ------

# ACLED (Armed Conflict Location & Event Data)
ACLED_EMAIL=""
ACLED_PASSWORD=""
ACLED_ACCESS_TOKEN=""

# UCDP (Uppsala Conflict Data Program)
UCDP_ACCESS_TOKEN=""

# ------ Internet & Infrastructure APIs ------

# Cloudflare Radar API
CLOUDFLARE_API_TOKEN=""

# Cloudflare R2 Storage
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_REGION="auto"

# ------ Satellite & Fire Detection ------

# NASA FIRMS (Fire Information for Resource Management System)
NASA_FIRMS_API_KEY=""

# ------ Telegram OSINT (optional) ------
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""
TELEGRAM_SESSION=""
TELEGRAM_CHANNEL_SET="full"

# ------ Relay Server (optional) ------
WS_RELAY_URL=""
RELAY_SHARED_SECRET=""
RELAY_AUTH_HEADER="x-relay-key"

# ------ Supply Chain Intelligence ------
CORRIDOR_RISK_API_KEY=""

# ------ Site Configuration ------

# Feature flags
WORLDMONITOR_API_KEY="local-dev-full-access"

# Map configuration
VITE_MAP_INTERACTION_MODE="3d"
VITE_PMTILES_URL=""

# ------ Authentication (optional) ------

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_JWT_ISSUER_DOMAIN=""

# ------ Monitoring (optional) ------

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""

# Vercel Analytics (auto-enabled on Vercel)
