// Unified Platform — Prisma Schema
// Combines Vane, Justyoo, and WorldMonitor data models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")      // Pooled connection for app runtime
  directUrl = env("DIRECT_URL")        // Direct connection for migrations
}

// ============================================
// Unified Authentication
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Justyoo relations
  profile   InvestorProfile?
  portfolio Portfolio?

  // Vane relations
  chats Chat[]

  @@index([email])
}

// ============================================
// Justyoo (Portfolio Management)
// ============================================

model InvestorProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  location           String
  age                Int
  experienceLevel    String    // BEGINNER | SOME | ACTIVE
  goal               String    // GROW | INCOME | SPECIFIC | PRESERVE
  goalDescription    String?
  targetDate         DateTime?
  timeHorizon        String    // LT2 | 2TO5 | 5TO10 | GT10
  capitalUSD         Decimal   @db.Decimal(18, 2)
  riskScore          Int       // 0–100
  riskProfile        String    // CONSERVATIVE | BALANCED | AGGRESSIVE
  profileOverride    Boolean   @default(false)
  esgOnly            Boolean   @default(false)
  excludedSectors    String[]
  excludedAssets     String[]
  rebalanceThreshold Decimal   @default(0.05) @db.Decimal(5, 4)
  currencyPreference String    @default("USD")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Portfolio {
  id             String   @id @default(uuid())
  userId         String   @unique
  virtualCash    Decimal  @db.Decimal(18, 2)
  totalValue     Decimal  @db.Decimal(18, 2)
  initialCapital Decimal  @db.Decimal(18, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     PortfolioHolding[]
  transactions Transaction[]
  rebalancings RebalancingLog[]

  @@index([userId])
}

model PortfolioHolding {
  id                   String   @id @default(uuid())
  portfolioId          String
  etfTicker            String
  targetWeight         Decimal  @db.Decimal(8, 6)
  currentWeight        Decimal  @db.Decimal(8, 6)
  units                Decimal  @db.Decimal(18, 6)
  averagePurchasePrice Decimal  @db.Decimal(18, 4)
  currentPrice         Decimal  @db.Decimal(18, 4)
  currentValue         Decimal  @db.Decimal(18, 2)
  gainLoss             Decimal  @db.Decimal(18, 2)
  returnPct            Decimal  @db.Decimal(8, 6)
  updatedAt            DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  etf       ETF       @relation(fields: [etfTicker], references: [ticker])

  @@unique([portfolioId, etfTicker])
  @@index([portfolioId])
  @@index([etfTicker])
}

model ETF {
  ticker                 String  @id
  name                   String
  assetClass             String  // Equities | Bonds | Real Estate | Commodities | Cash
  subCategory            String
  historicalAnnualReturn Decimal @db.Decimal(8, 6)
  historicalVolatility   Decimal @db.Decimal(8, 6)
  expenseRatio           Decimal @db.Decimal(8, 6)
  esgEligible            Boolean
  minimumInvestment      Decimal @db.Decimal(10, 2)

  holdings       PortfolioHolding[]
  correlationsA  ETFCorrelation[]   @relation("ETFCorrelationA")
  correlationsB  ETFCorrelation[]   @relation("ETFCorrelationB")
  transactions   Transaction[]
  priceSnapshots PriceSnapshot[]
}

model ETFCorrelation {
  etfTickerA  String
  etfTickerB  String
  correlation Decimal @db.Decimal(6, 4)

  etfA ETF @relation("ETFCorrelationA", fields: [etfTickerA], references: [ticker])
  etfB ETF @relation("ETFCorrelationB", fields: [etfTickerB], references: [ticker])

  @@id([etfTickerA, etfTickerB])
}

model Transaction {
  id          String   @id @default(uuid())
  portfolioId String
  etfTicker   String
  type        String   // BUY | SELL
  units       Decimal  @db.Decimal(18, 6)
  price       Decimal  @db.Decimal(18, 4)
  totalValue  Decimal  @db.Decimal(18, 2)
  reason      String   // MANUAL | REBALANCE | INITIAL
  createdAt   DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  etf       ETF       @relation(fields: [etfTicker], references: [ticker])

  @@index([portfolioId])
  @@index([etfTicker])
  @@index([createdAt])
}

model RebalancingLog {
  id          String    @id @default(uuid())
  portfolioId String
  triggeredAt DateTime  @default(now())
  trades      Json
  approvedAt  DateTime?
  status      String    // PENDING | APPROVED | REJECTED

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([status])
}

model PriceSnapshot {
  id       String   @id @default(uuid())
  ticker   String
  price    Decimal  @db.Decimal(18, 4)
  currency String   @default("USD")
  takenAt  DateTime @default(now())

  etf ETF @relation(fields: [ticker], references: [ticker])

  @@index([ticker, takenAt])
}

model CurrencySnapshot {
  id      String   @id @default(uuid())
  fromCcy String
  toCcy   String
  rate    Decimal  @db.Decimal(12, 6)
  takenAt DateTime @default(now())

  @@index([fromCcy, toCcy, takenAt])
}

// ============================================
// Vane (AI Chat)
// ============================================

model Chat {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([createdAt])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  role      String   // user | assistant | system
  content   String   @db.Text
  metadata  Json?    // sources, model, tokens, etc.
  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([createdAt])
}
