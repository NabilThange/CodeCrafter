# Kuberaa — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Local Development (use localhost)
DATABASE_URL="postgresql://kuberaa:kuberaa_dev_pass@localhost:5432/kuberaa?schema=public"

# Docker Environment (use service name 'postgres')
# DATABASE_URL="postgresql://kuberaa:kuberaa_dev_pass@postgres:5432/kuberaa?schema=public"

# Public app URL (used for absolute URL construction)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Cross-app navigation URLs
NEXT_PUBLIC_VANE_URL="http://localhost:3000"
NEXT_PUBLIC_WORLDMONITOR_URL="http://localhost:5173"

# PostgreSQL Configuration (for docker-compose)
POSTGRES_USER=kuberaa
POSTGRES_PASSWORD=kuberaa_dev_pass
POSTGRES_DB=kuberaa

# ExchangeRate API (open.er-api.com — free tier, no key needed)
# No key required for open.er-api.com free tier

# Optional: Polygon.io API key for live ETF prices
POLYGON_API_KEY=""

# Optional: Alpha Vantage API key (fallback for ETF prices)
ALPHA_VANTAGE_API_KEY=""
